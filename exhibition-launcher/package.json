{
    "name": "exhibition-launcher",
    "version": "1.0.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win",
        "build:portable": "electron-builder --win --config.win.target=portable"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "devDependencies": {
        "electron": "^37.1.0",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "electron-log": "^5.4.4",
        "json5": "^2.2.3"
    },
    "build": {
        "appId": "com.kswl.launcher",
        "productName": "KSWL-Exhibition-Launcher",
        "icon": "assets/kswl-logo256.ico",
        "files": [
            "main.js",
            "preload.js"
        ],
        "extraResources": [
            {
                "from": "renderer/",
                "to": "renderer/"
            },
            {
                "from": "templates/",
                "to": "templates/"
            },
            {
                "from": "works/",
                "to": "works/"
            },
            {
                "from": "assets/",
                "to": "assets/"
            },
            {
                "from": "config.json5",
                "to": "config.json5"
            }
        ],
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "dir"
        }
    }
}